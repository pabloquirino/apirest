{
  "ConnectionStrings": {
    "Default": "${DATABASE_URL}"
  },
  "JwtSettings": {
    "SecretKey":         "${JWT_SECRET_KEY}",
    "Issuer":            "ApiRest",
    "Audience":          "ApiRest.Client",
    "ExpiryMinutes":     15,
    "RefreshExpiryDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default":     "Warning",
      "Microsoft":   "Warning"
    }
  }
}